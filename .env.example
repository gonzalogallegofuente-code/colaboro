# Base de datos Postgres (la app crea sus propias tablas en esta BD)
DATABASE_URL=postgresql://workdesk:PASSWORD@localhost:5433/colaboro_dev

# PIN compartido para entrar a la app
COLABORO_PIN=1234

# Secreto para firmar la cookie de sesión (openssl rand -base64 32)
COLABORO_SECRET=cambia_esto_por_un_secreto_largo

# Zona horaria (afecta a "hoy" y al cálculo de la semana)
TZ=Europe/Madrid
